{
  "name": "@blinksocial/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "concurrently \"nx serve blinksocial-api\" \"nx serve blinksocial-web\"",
    "start:api": "nx serve blinksocial-api",
    "start:web": "nx serve blinksocial-web",
    "predevServer": "pkill -f 'n[x] serve blinksocial' 2>/dev/null; sudo -v",
    "devServer": "concurrently \"nx serve blinksocial-api\" \"sudo -E env PATH=$PATH $(command -v node) ./node_modules/.bin/nx serve blinksocial-web --port 80 --host 0.0.0.0 --allowed-hosts=all\"",
    "build": "nx build blinksocial-web && nx build blinksocial-api",
    "build:api": "nx build blinksocial-api",
    "build:web": "nx build blinksocial-web",
    "lint": "nx run-many --target=lint",
    "test": "nx run-many --target=test",
    "e2e": "nx e2e blinksocial-web-e2e",
    "prepare": "husky"
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/core": "~21.1.0",
    "@angular-devkit/schematics": "~21.1.0",
    "@angular/build": "~21.1.0",
    "@angular/cli": "~21.1.0",
    "@angular/compiler-cli": "~21.1.0",
    "@angular/language-service": "~21.1.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "^22.5.4",
    "@nx/devkit": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "^22.5.4",
    "@nx/nest": "^22.5.4",
    "@nx/node": "22.5.4",
    "@nx/playwright": "^22.5.4",
    "@nx/web": "22.5.4",
    "@nx/webpack": "22.5.4",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "~21.1.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "@swc/helpers": "^0.5.18",
    "@swc/jest": "^0.2.39",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-eslint": "^21.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jsdom": "^27.1.0",
    "nx": "^22.5.4",
    "prettier": "^2.8.8",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.8",
    "webpack-cli": "^5.1.4"
  },
  "workspaces": [
    "apps/*",
