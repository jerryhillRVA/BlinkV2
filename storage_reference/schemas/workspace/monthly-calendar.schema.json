{
  "$id": "https://blinksocial.io/schemas/monthly-calendar.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MonthlyCalendar",
  "type": "object",
  "required": ["month", "events"],
  "properties": {
    "month": { "type": "string", "pattern": "^\\d{4}-\\d{2}$", "description": "YYYY-MM format" },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/CalendarEvent" }
    },
    "summary": {
      "type": "object",
      "properties": {
        "totalPublish": { "type": "integer" },
        "totalMilestones": { "type": "integer" },
        "totalPhaseWindows": { "type": "integer" },
        "overdueCount": { "type": "integer" },
        "atRiskCount": { "type": "integer" },
        "byPlatform": {
          "type": "object",
          "description": "Event counts keyed by platform",
          "additionalProperties": { "type": "integer" }
        }
      }
    },
    "lastRebuilt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "CalendarEvent": {
      "type": "object",
      "required": ["id", "type", "contentItemId", "title", "date"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["publish", "milestone", "phase_window"] },
        "contentItemId": { "type": "string" },
        "title": { "type": "string" },
        "platform": { "$ref": "enums.schema.json#/$defs/Platform" },
        "contentType": { "$ref": "enums.schema.json#/$defs/ContentType" },
        "status": { "$ref": "enums.schema.json#/$defs/ContentStatus" },
        "owner": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time", "description": "For phase_window events" },
        "time": { "type": "string" },
        "milestoneType": { "$ref": "enums.schema.json#/$defs/MilestoneType" },
        "milestoneStatus": { "$ref": "enums.schema.json#/$defs/MilestoneStatus" },
        "phaseType": { "$ref": "enums.schema.json#/$defs/PhaseType" },
        "severity": { "$ref": "enums.schema.json#/$defs/Severity" },
        "isRequired": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    }
  }
}
