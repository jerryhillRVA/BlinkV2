{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@blinksocial/source"],
    "baseUrl": ".",
    "paths": {
      "@blinksocial/contracts": ["libs/blinksocial-contracts/src/index.ts"],
      "@blinksocial/contracts/validation": ["libs/blinksocial-contracts/src/lib/workspace/validation.ts"],
      "@blinksocial/core": ["libs/blinksocial-core/src/index.ts"],
      "@blinksocial/models": ["libs/blinksocial-models/src/index.ts"]
    }
  }
}
