{
  "name": "@blinksocial/blinksocial-api",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "blinksocial-api",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--node-env=production"
          ],
          "cwd": "apps/blinksocial-api"
        },
        "configurations": {
          "development": {
            "args": [
              "--node-env=development"
            ]
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/blinksocial-api/dist/package.json",
          "{workspaceRoot}/apps/blinksocial-api/dist/package-lock.json"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/blinksocial-api/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run --config apps/blinksocial-api/vitest.config.ts",
          "cwd": "."
        }
      },
      "serve": {
        "continuous": true,
        "executor": "nx:run-commands",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "configurations": {
          "development": {
            "commands": [
              "webpack-cli build --watch --node-env=development",
              "node --watch-path=./dist ./dist/main.js"
            ],
            "cwd": "apps/blinksocial-api",
            "parallel": true
          },
          "production": {
            "command": "node dist/main.js",
            "cwd": "apps/blinksocial-api"
          }
        }
      }
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0"
  }
}
