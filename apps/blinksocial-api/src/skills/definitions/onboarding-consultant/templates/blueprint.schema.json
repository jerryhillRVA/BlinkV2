{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BlueprintDocument",
  "type": "object",
  "required": [
    "clientName",
    "deliveredDate",
    "strategicSummary",
    "strategyInPlainEnglish",
    "strategicDecisions",
    "businessObjectives",
    "objectivesShapeContent",
    "brandVoice",
    "audienceProfiles",
    "targetAudience",
    "competitorLandscape",
    "differentiationMatrix",
    "differentiationSummary",
    "contentPillars",
    "channelsAndCadence",
    "contentChannelMatrix",
    "performanceScorecard",
    "reviewCadence",
    "quickWins"
  ],
  "properties": {
    "clientName": { "type": "string" },
    "deliveredDate": { "type": "string" },
    "strategicSummary": { "type": "string", "minLength": 100 },
    "strategyInPlainEnglish": { "type": "string", "minLength": 30 },
    "strategicDecisions": { "type": "string", "minLength": 30 },
    "businessObjectives": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["objective", "category", "timeHorizon", "metric"],
        "properties": {
          "objective": { "type": "string" },
          "category": { "type": "string" },
          "timeHorizon": { "type": "string" },
          "metric": { "type": "string" }
        }
      }
    },
    "objectivesShapeContent": { "type": "string", "minLength": 30 },
    "brandVoice": {
      "type": "object",
      "required": [
        "positioningStatement",
        "contentMission",
        "voiceAttributes",
        "doList",
        "dontList",
        "voiceInAction"
      ],
      "properties": {
        "positioningStatement": { "type": "string" },
        "contentMission": { "type": "string" },
        "voiceAttributes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["attribute", "description"],
            "properties": {
              "attribute": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "doList": { "type": "array", "items": { "type": "string" } },
        "dontList": { "type": "array", "items": { "type": "string" } },
        "voiceInAction": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["context", "sample"],
            "properties": {
              "context": { "type": "string" },
              "sample": { "type": "string" }
            }
          }
        }
      }
    },
    "audienceProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "demographics",
          "painPoints",
          "channels",
          "contentHook",
          "journeyMap"
        ],
        "properties": {
          "name": { "type": "string" },
          "demographics": { "type": "string" },
          "painPoints": { "type": "array", "items": { "type": "string" } },
          "channels": { "type": "array", "items": { "type": "string" } },
          "contentHook": { "type": "string" },
          "journeyMap": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": ["phase", "goal", "contentMoment"],
              "properties": {
                "phase": {
                  "type": "string",
                  "enum": ["Discovery", "Consideration", "Conversion", "Advocate"]
                },
                "goal": { "type": "string" },
                "contentMoment": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "targetAudience": { "type": "string", "minLength": 50 },
    "competitorLandscape": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "platforms", "strengths", "gaps", "relevancy"],
        "properties": {
          "name": { "type": "string" },
          "platforms": { "type": "array", "items": { "type": "string" } },
          "strengths": { "type": "array", "items": { "type": "string" } },
          "gaps": { "type": "array", "items": { "type": "string" } },
          "relevancy": { "type": "string" }
        }
      }
    },
    "differentiationMatrix": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["dimension", "hive", "competitors"],
        "properties": {
          "dimension": { "type": "string" },
          "hive": { "type": "string" },
          "competitors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "value"],
              "properties": {
                "name": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "differentiationSummary": { "type": "string", "minLength": 30 },
    "contentPillars": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["name", "description", "formats", "sharePercent", "contentIdeas"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "formats": { "type": "array", "items": { "type": "string" } },
          "sharePercent": { "type": "number", "minimum": 5, "maximum": 60 },
          "contentIdeas": {
            "type": "array",
            "minItems": 5,
            "items": {
              "type": "object",
              "required": ["title", "angle"],
              "properties": {
                "title": { "type": "string" },
                "angle": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "channelsAndCadence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["channel", "role", "frequency", "bestTimes", "contentTypes"],
        "properties": {
          "channel": { "type": "string" },
          "role": { "type": "string" },
          "frequency": { "type": "string" },
          "bestTimes": { "type": "string" },
          "contentTypes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "contentChannelMatrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["pillar", "placements"],
        "properties": {
          "pillar": { "type": "string" },
          "placements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["channel", "role"],
              "properties": {
                "channel": { "type": "string" },
                "role": { "type": "string", "enum": ["primary", "occasional"] }
              }
            }
          }
        }
      }
    },
    "performanceScorecard": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "metric",
          "baseline",
          "thirtyDayTarget",
          "ninetyDayTarget",
          "definition"
        ],
        "properties": {
          "metric": { "type": "string" },
          "baseline": { "type": "string" },
          "thirtyDayTarget": { "type": "string" },
          "ninetyDayTarget": { "type": "string" },
          "definition": { "type": "string", "minLength": 10 }
        }
      }
    },
    "reviewCadence": { "type": "string", "minLength": 30 },
    "quickWins": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string" }
    }
  }
}
