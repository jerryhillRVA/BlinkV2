# ─── Blink Social Environment Variables ───
#
# Each worktree should override these to its own port band so multiple
# agents can run `npm start` / `nx e2e` in parallel without colliding.
# See docs/worktrees.md for the bootstrap flow and the recovery steps
# when something else is already bound to your configured port.
#
# Per-agent allocation:
#
#   ┌──────────┬──────────┬──────────┬───────────────┐
#   │  Agent   │ API_PORT │ WEB_PORT │ API_E2E_PORT  │
#   ├──────────┼──────────┼──────────┼───────────────┤
#   │ canon    │     3000 │     4200 │          3001 │  ← integration worktree (default)
#   │ Agent 1  │     3101 │     4201 │          3201 │
#   │ Agent 2  │     3102 │     4202 │          3202 │
#   │ Agent 3  │     3103 │     4203 │          3203 │
#   └──────────┴──────────┴──────────┴───────────────┘
#
# `npm start` runs `scripts/check-ports.mjs` first and fails fast with
# the offending PID / cwd if the trio above isn't free.

# Application
PORT=3000
NODE_ENV=development

# Per-worktree port overrides — uncomment + edit per the table above.
# These must match what you set when running Playwright (BASE_URL and
# API_BASE_URL fall back to localhost:${WEB_PORT|API_PORT} when unset).
# API_PORT=3101
# WEB_PORT=4201
# API_E2E_PORT=3201

# AgenticFilesystem (omit or leave empty for mock mode with hardcoded workspaces)
# AGENTIC_FS_URL=http://localhost:8000
# AFS_PORT=8000   # used by apps/blinksocial-web/proxy.conf.js for /v1 + /admin

# Playwright e2e
# E2E_REUSE_SERVER=true   # opt-in; off by default so cross-worktree contamination
                          # cannot happen silently. See docs/worktrees.md.

# Privileged-port dev server (port 80, requires sudo). Singleton — only one
# worktree at a time can hold port 80. `npm run devServer` refuses to run
# unless this is set; pair it with `BLINK_DEV_SUDO=1` on the same line.
# BLINK_DEV_SUDO=1

# Database (future)
# DATABASE_URL=postgresql://user:password@localhost:5432/blinksocial

# Redis (future)
# REDIS_URL=redis://localhost:6379

# LLM Provider (required for AI skills — onboarding consultant, etc.)
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# When `true` (default), `LlmService.complete` emits a structured
# `llm-request` / `llm-response` payload at debug for every call: model,
# message count, system prompt, per-turn role + content length + first/last
# 200-char snippets, tools[], toolChoice, response content, tool-use input,
# stopReason, usage, and latency. API keys are scrubbed; per-field values
# cap at 4000 chars; image/document blocks log byte counts only.
#
# Verbose logging stays default-on while #94 reliability is stabilizing.
# Flip to `false` once parse-miss rates settle.
# LLM_VERBOSE_LOGGING=true
