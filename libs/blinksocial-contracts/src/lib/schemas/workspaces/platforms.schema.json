{
  "$id": "https://blinksocial.io/schemas/settings/platforms.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlatformSettings",
  "type": "object",
  "required": ["globalRules", "platforms"],
  "properties": {
    "globalRules": {
      "type": "object",
      "required": ["maxIdeasPerMonth"],
      "properties": {
        "maxIdeasPerMonth": { "type": "integer", "minimum": 1 },
        "contentWarningToggle": { "type": "boolean", "default": false },
        "aiDisclaimerToggle": { "type": "boolean", "default": false },
        "defaultPlatform": { "$ref": "https://blinksocial.io/schemas/enums.schema.json#/$defs/Platform" }
      }
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["platformId", "enabled"],
        "properties": {
          "platformId": { "$ref": "https://blinksocial.io/schemas/enums.schema.json#/$defs/Platform" },
          "enabled": { "type": "boolean" },
          "defaultResolution": { "type": "string" },
          "postingSchedule": { "type": "string" },
          "peakTimes": { "type": "array", "items": { "type": "string" } },
          "aiContentStyle": { "type": "string", "maxLength": 500 },
          "designPromptSuffix": { "type": "string", "maxLength": 500 }
        }
      }
    }
  }
}
