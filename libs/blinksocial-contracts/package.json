{
  "name": "@blinksocial/blinksocial-contracts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@blinksocial/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "name": "blinksocial-contracts",
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run --config libs/blinksocial-contracts/vitest.config.ts"
        }
      }
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  }
}
